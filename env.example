# GOV.UK Notify Configuration
# Get these from your GOV.UK Notify account dashboard

# API Key (required)
GOVUK_NOTIFY_API_KEY=your-api-key-here

# Email Template IDs (required for email notifications)
GOVUK_NOTIFY_VERIFY_EMAIL_TEMPLATE_ID=your-verify-email-template-id
GOVUK_NOTIFY_RESET_PASSWORD_TEMPLATE_ID=your-reset-password-template-id
GOVUK_NOTIFY_EMAIL_CHANGED_TEMPLATE_ID=your-email-changed-template-id

# SMS Template IDs (required for SMS notifications)
GOVUK_NOTIFY_2FA_CODE_TEMPLATE_ID=your-2fa-code-template-id
GOVUK_NOTIFY_MOBILE_CHANGED_TEMPLATE_ID=your-mobile-changed-template-id
GOVUK_NOTIFY_VERIFY_MOBILE_TEMPLATE_ID=your-verify-mobile-template-id

# Support Contact (optional)
SUPPORT_PHONE_NUMBER=0300 123 4567 